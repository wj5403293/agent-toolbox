<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

        <!-- ======== 头部 ======== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MCP 工具箱"
                    style="@style/TextTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agent 服务端"
                    style="@style/TextCaption"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="未启动"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/card_bg"
                android:textColor="@color/text_muted"
                android:gravity="center" />
        </LinearLayout>

        <!-- ======== 服务状态卡片 ======== -->
        <LinearLayout
            style="@style/Card"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务状态"
                style="@style/TextCaption"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="服务"
                    style="@style/TextBody" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未启动"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="监听地址"
                    style="@style/TextBody" />

                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/card_bg"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ======== 操作按钮区 ======== -->
        <LinearLayout
            style="@style/Card"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="启动 MCP 服务"
                android:textColor="@color/text_inverse"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:layout_marginBottom="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="停止服务"
                android:textColor="@color/text_inverse"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_danger"
                android:enabled="false"
                android:layout_marginBottom="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnDeepSeek"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="打开 DeepSeek 助手"
                android:textColor="@color/accent"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/card_bg"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- ======== 请求日志 ======== -->
        <LinearLayout
            style="@style/Card"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请求日志"
                style="@style/TextCaption"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_light"
                android:layout_marginBottom="12dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/background_alt"
                android:padding="12dp"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextMono"
                    android:textIsSelectable="true"
                    android:longClickable="true" />
            </ScrollView>
        </LinearLayout>

        <!-- ======== 技能安装目录 ======== -->
        <TextView
            android:id="@+id/tvSkillsPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:background="@drawable/card_bg"
            android:visibility="gone" />

    <!-- ======== DeepSeek WebView 容器 ======== -->
    <FrameLayout
        android:id="@+id/deepseekContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 顶部工具栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/btnDeepSeekBack"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="← 返回"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/card_bg" />

                <TextView
                    android:id="@+id/tvDeepSeekStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DeepSeek"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvLoginStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测中..."
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginRight="8dp" />

                <TextView
                    android:id="@+id/btnNewChat"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="新会话"
                    android:textSize="13sp"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnRefreshDS"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="刷新"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/card_bg" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/deepseekWebView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 底部 MCP 状态栏 -->
            <TextView
                android:id="@+id/tvMcpStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_margin="4dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
</LinearLayout>
