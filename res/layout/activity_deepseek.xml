<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ======== 顶部工具栏（紧凑） ======== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:elevation="1dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="←"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/card_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/tvLoginStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="检测中..."
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:gravity="center" />

        <Button
            android:id="@+id/btnNewChat"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="新会话"
            android:textSize="12sp"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:background="@null"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="刷新"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/card_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnExtractHtml"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="提取"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/card_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- ======== WebView 容器 ======== -->
    <FrameLayout
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ======== MCP 工具箱浮动层（覆盖全屏，与 DeepSeek 共存） ======== -->
    <FrameLayout
        android:id="@+id/mcpOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone">

        <WebView
            android:id="@+id/mcpWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- ======== 底部状态栏 ======== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:elevation="1dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="就绪"
            style="@style/TextCaption" />

        <TextView
            android:id="@+id/tvMcpStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MCP: 未连接"
            android:textSize="12sp"
            android:textColor="@color/error"
            android:textStyle="bold"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/card_bg" />
    </LinearLayout>

</LinearLayout>
